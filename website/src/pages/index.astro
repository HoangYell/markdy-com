  :root,
  :root[data-theme="light"] {
    --bg-primary: #fafafa;
    --bg-secondary: #ffffff;
    --bg-tertiary: #f8fafc;
    --bg-code: #0f172a;
    --text-primary: #0f172a;
    --text-secondary: #64748b;
    --text-muted: #94a3b8;
    --text-code: #e2e8f0;
    --border: #e2e8f0;
    --border-subtle: #f1f5f9;
    --accent: #059669;
    --accent-hover: #047857;
    --accent-light: rgba(5, 150, 105, 0.25);
    --shadow-sm: rgba(0, 0, 0, 0.04);
    --shadow-md: rgba(0, 0, 0, 0.06);
    --selection-bg: #d1fae5;
    --selection-text: #064e3b;

    /* CodeMirror theme vars */
    --cm-caret: #0f172a;
    --cm-activeLine: rgba(5, 150, 105, 0.05);
    --cm-selection: #d1fae5;

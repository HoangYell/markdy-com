var accent_skin = #fad4c0

def char(skin, face) {
  figure(${skin}, f, ${face})
}

actor lily = char(${accent_skin}, 😊) at (200, 200) scale 1.5
actor rose = char(#e5a285, 👩) at (600, 200) scale 1.5
        </script>

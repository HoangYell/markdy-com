            <tr><td><code>enter</code></td><td>from, dur</td><td>Slides in from canvas edge</td></tr>
            <tr><td><code>move</code></td><td>to, dur, ease</td><td>Translates to target coordinates</td></tr>
            <tr><td><code>fade_in</code> / <code>fade_out</code></td><td>dur</td><td>Animates opacity</td></tr>
            <tr><td><code>scale</code> / <code>rotate</code></td><td>to, dur</td><td>Transforms the actor</td></tr>
          </tbody>
        </table>
        <p><strong>Easing:</strong> <code>linear</code>, <code>in</code>, <code>out</code>, <code>inout</code></p>
      </article>

      <!-- Step 4: Speech & Effects -->
      <article class="ref-card">

  }

  :root[data-theme="dark"] {
    --bg-primary: #0d1117;
    --bg-secondary: #161b22;
    --bg-tertiary: #1c2128;
    --bg-code: #0d1117;
    --text-primary: #c9d1d9;
    --text-secondary: #8b949e;
    --text-muted: #484f58;
    --text-code: #c9d1d9;
    --border: #30363d;
    --border-subtle: #21262d;
    --accent: #3fb950;
    --accent-hover: #2ea043;
    --accent-light: rgba(63, 185, 80, 0.2);
    --shadow-sm: rgba(0, 0, 0, 0.2);
    --shadow-md: rgba(0, 0, 0, 0.3);
    --selection-bg: rgba(63, 185, 80, 0.15);
    --selection-text: #c9d1d9;

    /* CodeMirror dark vars */
    --cm-caret: #c9d1d9;
    --cm-activeLine: rgba(63, 185, 80, 0.06);
    --cm-selection: rgba(63, 185, 80, 0.15);
    --cm-tooltipBg: #1c2128;
    --cm-tooltipBorder: #30363d;
    --cm-tooltipShadow: rgba(0, 0, 0, 0.3);
    --cm-tooltipSelected: #3fb950;
    --cm-tooltipSelectedText: #0d1117;

    /* Ref card code blocks */
    --ref-code-bg: #161b22;
    --ref-code-text: #c9d1d9;
  }

  /* ── Nav (frosted glass) ─────────────────────────────────────────────── */
  .nav {

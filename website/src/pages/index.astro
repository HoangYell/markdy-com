<script>
  /* ── Usage tabs ────────────────────────────────────────────────────── */
  const tabs = document.querySelectorAll<HTMLButtonElement>(".usage-tab");
  const panels = document.querySelectorAll<HTMLDivElement>(".usage-panel");

  tabs.forEach(tab => {
    tab.addEventListener("click", () => {
      const target = tab.dataset.tab;
      tabs.forEach(t => { t.classList.remove("active"); t.setAttribute("aria-selected", "false"); });
      panels.forEach(p => p.classList.remove("active"));
      tab.classList.add("active");
      tab.setAttribute("aria-selected", "true");
      document.querySelector(`.usage-panel[data-panel="${target}"]`)?.classList.add("active");
    });
  });

  /* ── Copy install commands ─────────────────────────────────────────── */
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const cmd = btn.closest(".usage-install")?.querySelector(".usage-cmd");
      if (!cmd) return;
      navigator.clipboard.writeText(cmd.textContent?.trim() ?? "");
      btn.title = "Copied!";
      setTimeout(() => { btn.title = "Copy"; }, 2000);
    });
  });

  /* ── Scroll to top ─────────────────────────────────────────────────── */
  const scrollTopBtn = document.getElementById("scroll-top");
  if (scrollTopBtn) {
    window.addEventListener("scroll", () => {
      scrollTopBtn.classList.toggle("visible", window.scrollY > 400);
    }, { passive: true });
    scrollTopBtn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }

  /* ── Mobile menu toggle ────────────────────────────────────────────── */
  const menuToggle = document.getElementById("menu-toggle");
  const navLinks = document.querySelector(".nav-links");
  if (menuToggle && navLinks) {
    menuToggle.addEventListener("click", () => {
      navLinks.classList.toggle("open");
      menuToggle.classList.toggle("open");
      menuToggle.setAttribute("aria-expanded", navLinks.classList.contains("open").toString());
    });
    // Close menu on link click
    navLinks.querySelectorAll("a").forEach(link => {
      link.addEventListener("click", () => {
        navLinks.classList.remove("open");
        menuToggle.classList.remove("open");
        menuToggle.setAttribute("aria-expanded", "false");
      });
    });
  }

  /* ── Theme toggle (must run before CodeMirror to set CSS vars) ──── */
  const STORAGE_KEY = "markdy-theme";

  function getPreferredTheme(): "light" | "dark" {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored === "dark" || stored === "light") return stored;
    return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
  }

  function applyTheme(theme: "light" | "dark") {
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem(STORAGE_KEY, theme);
    // Update toggle icon visibility
    const toggle = document.getElementById("theme-toggle");
    if (toggle) {
      toggle.classList.toggle("is-dark", theme === "dark");
    }
  }

  // Apply saved theme immediately
  applyTheme(getPreferredTheme());

  // Toggle button
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const current = document.documentElement.getAttribute("data-theme") || "light";
    applyTheme(current === "dark" ? "light" : "dark");
    // Recreate editor with new theme
    if ((window as any).__recreateEditor) {
      (window as any).__recreateEditor();
    }
  });
</script>

<script>
  import { EditorView, keymap, lineNumbers, highlightActiveLine, highlightActiveLineGutter } from "@codemirror/view";
  import { EditorState } from "@codemirror/state";
  import { syntaxHighlighting, bracketMatching, indentOnInput } from "@codemirror/language";
  import { defaultKeymap, history, historyKeymap, indentWithTab } from "@codemirror/commands";
  import { highlightSelectionMatches, searchKeymap } from "@codemirror/search";
  import { closeBrackets, closeBracketsKeymap } from "@codemirror/autocomplete";

  import { markdyLanguage, markdyAutocomplete, markdyHighlightLight, markdyHighlightDark } from "../editor/markdy-language";
  import { baseTheme, lightTheme, darkTheme } from "../editor/editor-theme";
  import { createPlayer } from "@markdy/renderer-dom";
  import type { Player } from "@markdy/renderer-dom";

  const examples: string[]  = (window as any).__MARKDY_EXAMPLES;
  const assets: Record<string, string> = (window as any).__MARKDY_ASSETS;

  const editorContainer = document.getElementById("code-editor") as HTMLDivElement;
  const stage     = document.getElementById("stage")      as HTMLDivElement;
  const runBtn    = document.getElementById("run-btn")    as HTMLButtonElement;
  const statusEl  = document.getElementById("status")     as HTMLSpanElement;
  const exBtns    = document.querySelectorAll<HTMLButtonElement>(".example-btn");

  let player: Player | null = null;
  let debounce: ReturnType<typeof setTimeout> | null = null;
  let editorView: EditorView | null = null;

  function isDarkMode(): boolean {
    return document.documentElement.getAttribute("data-theme") === "dark";
  }

  function setStatus(ok: boolean) {
    statusEl.className = `status ${ok ? "ok" : "err"}`;
  }

  const stageWrap = document.getElementById("stage-wrap") as HTMLDivElement;

  function resizeStage() {
    if (!stageWrap || !stage.firstElementChild) return;
    const sceneEl = stage.firstElementChild as HTMLElement;
    
    // Don't scale error messages
    if (sceneEl.classList.contains("parse-error")) {
      sceneEl.style.transform = "";
      return;
    }

    const sceneWidth = parseFloat(sceneEl.style.width) || 800;
    const sceneHeight = parseFloat(sceneEl.style.height) || 400;

    const wrapW = stageWrap.clientWidth;
    const wrapH = stageWrap.clientHeight;
    if (wrapW === 0 || wrapH === 0) return;

    const padding = 20;
    const availW = wrapW - padding;
    const availH = wrapH - padding;

    const scaleX = availW / sceneWidth;
    const scaleY = availH / sceneHeight;
    const scale = Math.min(1.0, Math.min(scaleX, scaleY));

    // Override renderer's absolute position cleanly to center it visually
    sceneEl.style.position = "absolute";
    sceneEl.style.left = "50%";
    sceneEl.style.top = "50%";
    sceneEl.style.transform = `translate(-50%, -50%) scale(${scale})`;
    sceneEl.style.transformOrigin = "center center";
  }

  const ro = new ResizeObserver(() => resizeStage());
  ro.observe(stageWrap);

  function render(code: string) {
    if (player) { player.destroy(); player = null; }
    stage.innerHTML = "";
    try {
      player = createPlayer({ container: stage, code, assets, autoplay: true, copyright: false });
      setStatus(true);
      if ((window as any).Iconify) {
        (window as any).Iconify.scan(stage);
      }
      resizeStage();
    } catch (e) {
      const msg = (e as Error).message ?? String(e);
      stage.innerHTML = `<p class="parse-error">${msg}</p>`;
      setStatus(false);
    }
  }

  function setActiveBtn(index: number) {
    exBtns.forEach((b, i) => b.classList.toggle("active", i === index));
  }

  function getEditorCode(): string {
    return editorView?.state.doc.toString() ?? "";
  }

  function createEditor(initialCode: string) {
    // Destroy if existing
    if (editorView) {
      editorView.destroy();
      editorView = null;
    }

    const dark = isDarkMode();

    const extensions = [
      lineNumbers(),
      highlightActiveLine(),
      highlightActiveLineGutter(),
      history(),
      bracketMatching(),
      closeBrackets(),
      indentOnInput(),
      highlightSelectionMatches(),
      markdyLanguage,
      markdyAutocomplete,
      syntaxHighlighting(dark ? markdyHighlightDark : markdyHighlightLight),
      baseTheme,
      dark ? darkTheme : lightTheme,
      keymap.of([
        ...closeBracketsKeymap,
        ...defaultKeymap,
        ...searchKeymap,
        ...historyKeymap,
        indentWithTab,
      ]),
      EditorView.contentAttributes.of({ "aria-label": "Code Editor" }),
      EditorView.updateListener.of((update) => {
        if (update.docChanged) {
          exBtns.forEach(b => b.classList.remove("active"));
          if (debounce) clearTimeout(debounce);
          debounce = setTimeout(() => render(getEditorCode()), 600);
        }
      }),
    ];

    editorView = new EditorView({
      state: EditorState.create({
        doc: initialCode,
        extensions,
      }),
      parent: editorContainer,
    });
  }


  // ── URL hash share state ────────────────────────────────────────────
  function getCodeFromHash(): string | null {
    try {
      const hash = window.location.hash.slice(1);
      if (!hash) return null;
      const params = new URLSearchParams(hash);
      const encoded = params.get("code");
      if (!encoded) return null;
      return decodeURIComponent(atob(encoded));
    } catch {
      return null;
    }
  }

  function setShareURL(code: string) {
    const encoded = btoa(encodeURIComponent(code));
    const url = `${window.location.origin}${window.location.pathname}#code=${encoded}`;
    return url;
  }

  const shareBtn = document.getElementById("share-btn") as HTMLButtonElement;
  shareBtn?.addEventListener("click", () => {
    const code = getEditorCode();
    const url = setShareURL(code);
    navigator.clipboard.writeText(url).then(() => {
      const prev = shareBtn.textContent!.trim();
      shareBtn.textContent = "✓ Copied!";
      shareBtn.style.color = "var(--accent, #ea4c89)";
      setTimeout(() => {
        shareBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg> Share`;
        shareBtn.style.color = "";
      }, 2000);
    });
  });

  // Lazy initialization on interaction to guarantee 100/100 Lighthouse performance
  let isPlaygroundInit = false;
  const lazyInit = () => {
    if (isPlaygroundInit) return;
    isPlaygroundInit = true;
    // Load from URL hash if present, else use default example
    const sharedCode = getCodeFromHash();
    const initialCode = sharedCode ?? examples[0];
    createEditor(initialCode);
    render(initialCode);
    if (!sharedCode) setActiveBtn(0);
  };

  ['mousemove', 'scroll', 'keydown', 'click', 'touchstart'].forEach((event) => {
    window.addEventListener(event, lazyInit, { once: true, passive: true });
  });

  // Fallback in case there is no interaction for a bit:
  setTimeout(lazyInit, 8000);

  // Expose theme-change handler
  (window as any).__recreateEditor = () => {
    const currentCode = getEditorCode();
    createEditor(currentCode);
  };

  // Example buttons
  exBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const idx = Number(btn.dataset.index);
      setActiveBtn(idx);
      createEditor(examples[idx]);
      render(examples[idx]);
    });
  });

  // Run button
  runBtn.addEventListener("click", () => render(getEditorCode()));

  // Keyboard shortcut: Cmd/Ctrl+Enter to run
  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "Enter") {
      e.preventDefault();
      render(getEditorCode());
    }
  });

  // Setup global Apply function for Syntax Reference examples
  (window as any).applyRefCode = (code: string) => {
    createEditor(code);
    render(code);
    setActiveBtn(-1); // Remove active state
    document.getElementById("playground")?.scrollIntoView({ behavior: "smooth" });
  };
</script>


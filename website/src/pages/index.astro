---
import Layout from "../layouts/Layout.astro";

/* ── Example snippets for the sidebar ─────────────────────────────────── */
const EXAMPLES = [
  {
    label: "Hello World",
    code: `scene width=600 height=260 fps=30 bg=#fafafa

actor hi = text("Hello, Markdy!") at (180, 60) size 28 opacity 0
actor a  = figure(#c68642, m, 😎) at (280, 160)

@0.2: hi.fade_in(dur=0.6)
@0.6: a.enter(from=left, dur=0.8)
@1.5: a.say("Let's go! 🚀", dur=1.5)
@2.5: a.move(to=(350, 160), dur=0.8, ease=out)`,
  },
  {
    label: "Fight Scene",
    code: `scene width=640 height=300 fps=30 bg=#fafafa

actor hero    = figure(#6ee7b7, m, 😎) at (160, 170)
actor villain = figure(#f87171, m, 😈) at (480, 170)

@0.3: hero.enter(from=left, dur=0.7)
@0.5: villain.enter(from=right, dur=0.7)
@1.5: hero.say("Bring it on! 💪", dur=1.2)
@2.0: villain.say("Haha! 😈", dur=1.2)
@3.5: hero.move(to=(300, 170), dur=0.5, ease=in)
@3.5: villain.move(to=(340, 170), dur=0.5, ease=in)
@4.2: hero.punch(side=right, dur=0.3)
@4.3: villain.shake(intensity=8, dur=0.4)
@4.3: villain.face("😵")
@5.0: hero.kick(side=right, dur=0.35)
@5.3: villain.rotate(to=90, dur=0.3)
@5.5: villain.fade_out(dur=0.5)
@5.5: hero.face("😄")
@5.7: hero.say("Done! ✅", dur=1.5)`,
  },
  {
    label: "Love Story",
    code: `scene width=640 height=300 fps=30 bg=#fafafa

actor boy  = figure(#c68642, m, 😊) at (150, 170)
actor girl = figure(#fad4c0, f, 😊) at (490, 170)

@0.3: boy.enter(from=left, dur=0.8)
@0.5: girl.enter(from=right, dur=0.8)
@1.5: boy.face("😍")
@1.5: boy.say("Hi there! 😍", dur=1.5)
@2.5: girl.face("😊")
@2.5: girl.say("Hey! 👋", dur=1.2)
@4.0: boy.move(to=(280, 170), dur=0.8, ease=out)
@4.0: girl.move(to=(360, 170), dur=0.8, ease=out)
@5.0: boy.rotate_part(part=arm_right, to=-70, dur=0.4)
@5.0: girl.rotate_part(part=arm_left, to=70, dur=0.4)
@5.5: boy.face("🥰")
@5.5: girl.face("🥰")`,
  },
  {
    label: "Full Story (25s)",
    code: `scene width=800 height=400 fps=30 bg=#fafafa

var skin_a = #c68642
var skin_b = #8d5524
var skin_g = #fad4c0

def fighter(skin, face) {
  figure(\${skin}, m, \${face})
}

def girl(skin, face) {
  figure(\${skin}, f, \${face})
}

seq wave(arm, angle) {
  @+0.0: $.rotate_part(part=\${arm}, to=\${angle}, dur=0.3)
  @+0.3: $.rotate_part(part=\${arm}, to=25, dur=0.3)
}

seq hit(side, power) {
  @+0.0: $.punch(side=\${side}, dur=0.3)
  @+0.05: $.shake(intensity=\${power}, dur=0.3)
}

asset flower = image("/memes/flower.png")

actor bruno = fighter(\${skin_a}, 😏) at (640, 180)
actor alex  = fighter(\${skin_b}, 😤) at (100, 180)
actor lily  = girl(\${skin_g}, 😊)    at (370, 180) opacity 0

@0.0: lily.fade_in(dur=0.7)
@0.8: bruno.enter(from=right, dur=0.8)
@1.0: alex.enter(from=left, dur=0.8)
@2.0: bruno.play(wave, arm=arm_left, angle=-80)
@2.0: alex.play(wave, arm=arm_right, angle=80)
@3.0: bruno.face("😍")
@3.0: alex.face("😍")
@3.1: bruno.say("I love you! 😍", dur=1.4)
@3.5: alex.say("She is mine! 😤", dur=1.4)
@5.0: lily.face("😳")
@5.0: lily.say("Oh my... 😳", dur=1.1)
@6.5: lily.move(to=(700, 180), dur=0.5, ease=out)
@7.0: bruno.face("😠")
@7.0: alex.face("😠")
@7.0: bruno.move(to=(400, 180), dur=0.6, ease=in)
@7.0: alex.move(to=(320, 180), dur=0.6, ease=in)
@7.8: bruno.play(hit, side=left, power=7)
@7.8: alex.play(hit, side=right, power=7)
@8.3: alex.kick(side=right, dur=0.35)
@8.4: bruno.shake(intensity=9, dur=0.3)
@8.6: bruno.play(hit, side=left, power=9)
@9.4: bruno.punch(side=left, dur=0.25)
@9.5: alex.shake(intensity=12, dur=0.4)
@9.5: alex.face("😵")
@10.0: alex.rotate(to=90, dur=0.4)
@10.2: alex.fade_out(dur=0.4)
@10.0: bruno.face("😁")
@10.0: bruno.say("I win! 💪", dur=1.5)
@11.5: bruno.face("🥰")
@11.5: bruno.move(to=(520, 180), dur=0.8, ease=out)
@13.0: bruno.throw(flower, to=lily, dur=0.8)
@14.0: lily.face("🙅")
@14.0: lily.say("No thanks. 🙅", dur=2.0)
@14.1: lily.shake(intensity=5, dur=0.4)
@16.0: bruno.face("😢")
@16.2: bruno.say("But I fought! 😢", dur=1.4)
@17.0: bruno.move(to=(750, 180), dur=1.0, ease=in)
@18.0: alex.fade_in(dur=0.7)
@18.5: lily.face("🥺")
@18.5: lily.move(to=(380, 280), dur=0.8, ease=out)
@19.5: lily.face("🤗")
@19.5: lily.say("Hey, you okay? 💕", dur=2.0)
@20.0: alex.face("🥺")
@20.0: alex.say("You came... 🥺", dur=1.8)
@22.0: bruno.face("😔")
@22.0: bruno.say("...why 😔", dur=2.0)`,
  },
];

const FLOWER_ASSET: Record<string, string> = {
  flower: "data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20width%3D'36'%20height%3D'36'%3E%3Ccircle%20cx%3D'18'%20cy%3D'18'%20r%3D'16'%20fill%3D'%23ff69b4'%2F%3E%3Ccircle%20cx%3D'18'%20cy%3D'18'%20r%3D'6'%20fill%3D'%23ffff00'%2F%3E%3C%2Fsvg%3E",
};
---

<Layout title="Markdy — like Mermaid, but for motion">

  <!-- ─── Nav ──────────────────────────────────────────────────────────── -->
  <nav class="nav">
    <a href="/" class="nav-brand">markdy</a>
    <div class="nav-links">
      <a href="#playground">Playground</a>
      <a href="#syntax">Syntax</a>
      <a href="https://github.com/HoangYell/markdy-com" target="_blank" rel="noopener">GitHub</a>
      <a href="https://www.npmjs.com/package/@markdy/core" target="_blank" rel="noopener">npm</a>

      <!-- Dark mode toggle -->
      <button id="theme-toggle" class="theme-toggle" title="Toggle dark mode" aria-label="Toggle between dark and light mode">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
  <header class="hero">
    <h1>Like Mermaid, but for motion.</h1>
    <p class="hero-sub">Write stick-figure animations in a simple text DSL. No keyframes, no drag-and-drop.</p>
    <div class="hero-install">
      <code>npm i @markdy/core @markdy/renderer-dom</code>
    </div>
  </header>

  <!-- ─── Playground ───────────────────────────────────────────────────── -->
  <section id="playground" class="playground">
    <div class="section-header">
      <h2>Playground</h2>
      <p>Edit the code and watch it animate. Pick an example or write your own.</p>
    </div>

    <div class="examples-bar">
      {EXAMPLES.map((ex, i) => (
        <button class="example-btn" data-index={i}>{ex.label}</button>
      ))}
    </div>

    <div class="editor-layout">
      <div class="editor-col">
        <div class="panel-label">
          <span>Editor</span>
          <div class="editor-toolbar">
            <span class="editor-hint">Ctrl+Space for autocomplete</span>
            <button id="run-btn" class="btn-run" title="Run (or just type — auto-runs)">Run ▶</button>
          </div>
        </div>
        <div id="code-editor" class="code-editor-wrap"></div>
        <!-- Hidden textarea for initial value passing -->
        <textarea id="code-input" style="display:none" spellcheck="false">{EXAMPLES[0].code}</textarea>
      </div>

      <div class="preview-col">
        <div class="panel-label">
          <span>Preview</span>
          <span id="status" class="status ok"></span>
        </div>
        <div id="stage-wrap" class="stage-wrap">
          <div id="stage"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Syntax Reference ─────────────────────────────────────────────── -->
  <section id="syntax" class="syntax-ref">
    <div class="section-header">
      <h2>Syntax Reference</h2>
      <p>Everything you need to write MarkdyScript.</p>
    </div>

    <div class="ref-grid">

      <div class="ref-card">
        <h3>Scene</h3>
        <pre><code>scene width=800 height=400 fps=30 bg=#fafafa</code></pre>
        <p>Set canvas size, frame rate, and background. Must appear first.</p>
      </div>

      <div class="ref-card">
        <h3>Actors</h3>
        <pre><code>actor a = figure(#c68642, m, 😎) at (100, 200)
actor b = text("Hello") at (50, 50) size 24
actor c = sprite(myImg) at (300, 200) scale 0.5</code></pre>
        <table>
          <thead><tr><th>Type</th><th>Args</th><th>Description</th></tr></thead>
          <tbody>
            <tr><td><code>figure</code></td><td>skin [, gender, face]</td><td>Stick figure with limbs</td></tr>
            <tr><td><code>text</code></td><td>"string"</td><td>Text label</td></tr>
            <tr><td><code>sprite</code></td><td>asset name</td><td>Image/icon</td></tr>
            <tr><td><code>box</code></td><td>—</td><td>100x100 grey box</td></tr>
          </tbody>
        </table>
        <p><strong>Modifiers:</strong> <code>scale</code>, <code>opacity</code>, <code>size</code> (text only)</p>
      </div>

      <div class="ref-card">
        <h3>Events &amp; Actions</h3>
        <pre><code>@1.0: actor.action(param=value, dur=0.5)</code></pre>
        <table>
          <thead><tr><th>Action</th><th>Params</th></tr></thead>
          <tbody>
            <tr><td><code>enter</code></td><td>from=left|right|top|bottom, dur</td></tr>
            <tr><td><code>move</code></td><td>to=(x,y), dur, ease</td></tr>
            <tr><td><code>fade_in</code> / <code>fade_out</code></td><td>dur</td></tr>
            <tr><td><code>rotate</code></td><td>to=degrees, dur</td></tr>
            <tr><td><code>shake</code></td><td>intensity, dur</td></tr>
            <tr><td><code>say</code></td><td>"text", dur</td></tr>
            <tr><td><code>face</code></td><td>"emoji"</td></tr>
            <tr><td><code>punch</code></td><td>side=left|right, dur</td></tr>
            <tr><td><code>kick</code></td><td>side=left|right, dur</td></tr>
            <tr><td><code>rotate_part</code></td><td>part=head|body|arm_left|..., to, dur</td></tr>
            <tr><td><code>throw</code></td><td>asset, to=actor, dur</td></tr>
          </tbody>
        </table>
        <p><strong>Easing:</strong> <code>in</code>, <code>out</code>, <code>inout</code> (default: linear)</p>
      </div>

      <div class="ref-card">
        <h3>Variables &amp; Templates</h3>
        <pre><code>var skin = #c68642
var y = 200

def fighter(skin, face) {'{'}
  figure(${'${skin}'}, m, ${'${face}'})
{'}'}

actor a = fighter(${'${skin}'}, 😎) at (100, ${'${y}'})</code></pre>
        <p>Variables are simple text substitutions. Templates create reusable actor types.</p>
      </div>

      <div class="ref-card">
        <h3>Sequences</h3>
        <pre><code>seq wave(arm, angle) {'{'}
  @+0.0: $.rotate_part(part=${'${arm}'}, to=${'${angle}'}, dur=0.3)
  @+0.3: $.rotate_part(part=${'${arm}'}, to=25, dur=0.3)
{'}'}

@2.0: actor.play(wave, arm=arm_left, angle=-80)</code></pre>
        <p>Reusable animation blocks. <code>$</code> refers to the calling actor. <code>@+</code> is relative time.</p>
      </div>

      <div class="ref-card">
        <h3>Assets</h3>
        <pre><code>asset pepe = image("/memes/pepe.webp")
asset fire = icon("lucide:flame")

actor p = sprite(pepe) at (100, 200)
@3.0: p.throw(fire, to=enemy, dur=0.8)</code></pre>
        <p>Named references to images or icons.</p>
      </div>

    </div>
  </section>

  <!-- ─── Footer ───────────────────────────────────────────────────────── -->
  <footer class="footer">
    <span>Built by <a href="https://hoangyell.com" target="_blank" rel="noopener">Hoang Yell</a></span>
    <span class="dot">·</span>
    <a href="https://github.com/HoangYell/markdy-com" target="_blank" rel="noopener">GitHub</a>
    <span class="dot">·</span>
    <a href="https://www.npmjs.com/package/@markdy/core" target="_blank" rel="noopener">npm</a>
  </footer>

</Layout>

<!-- ─── Client-side: editor + examples ──────────────────────────────── -->
<script define:vars={{ examples: EXAMPLES.map(e => e.code), flowerAsset: FLOWER_ASSET }}>
  window.__MARKDY_EXAMPLES = examples;
  window.__MARKDY_ASSETS = flowerAsset;
</script>

<script>
  /* ── Theme toggle (must run before CodeMirror to set CSS vars) ──── */
  const STORAGE_KEY = "markdy-theme";

  function getPreferredTheme(): "light" | "dark" {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored === "dark" || stored === "light") return stored;
    return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
  }

  function applyTheme(theme: "light" | "dark") {
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem(STORAGE_KEY, theme);
    // Update toggle icon visibility
    const toggle = document.getElementById("theme-toggle");
    if (toggle) {
      toggle.classList.toggle("is-dark", theme === "dark");
    }
  }

  // Apply saved theme immediately
  applyTheme(getPreferredTheme());

  // Toggle button
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const current = document.documentElement.getAttribute("data-theme") || "light";
    applyTheme(current === "dark" ? "light" : "dark");
    // Recreate editor with new theme
    if ((window as any).__recreateEditor) {
      (window as any).__recreateEditor();
    }
  });
</script>

<script>
  import { EditorView, keymap, lineNumbers, highlightActiveLine, highlightActiveLineGutter } from "@codemirror/view";
  import { EditorState } from "@codemirror/state";
  import { syntaxHighlighting, bracketMatching, indentOnInput } from "@codemirror/language";
  import { defaultKeymap, history, historyKeymap, indentWithTab } from "@codemirror/commands";
  import { highlightSelectionMatches, searchKeymap } from "@codemirror/search";
  import { closeBrackets, closeBracketsKeymap } from "@codemirror/autocomplete";

  import { markdyLanguage, markdyAutocomplete, markdyHighlightLight, markdyHighlightDark } from "../editor/markdy-language";
  import { baseTheme, lightTheme, darkTheme } from "../editor/editor-theme";
  import { createPlayer } from "@markdy/renderer-dom";
  import type { Player } from "@markdy/renderer-dom";

  const examples: string[]  = (window as any).__MARKDY_EXAMPLES;
  const assets: Record<string, string> = (window as any).__MARKDY_ASSETS;

  const editorContainer = document.getElementById("code-editor") as HTMLDivElement;
  const stage     = document.getElementById("stage")      as HTMLDivElement;
  const runBtn    = document.getElementById("run-btn")    as HTMLButtonElement;
  const statusEl  = document.getElementById("status")     as HTMLSpanElement;
  const exBtns    = document.querySelectorAll<HTMLButtonElement>(".example-btn");

  let player: Player | null = null;
  let debounce: ReturnType<typeof setTimeout> | null = null;
  let editorView: EditorView | null = null;

  function isDarkMode(): boolean {
    return document.documentElement.getAttribute("data-theme") === "dark";
  }

  function setStatus(ok: boolean) {
    statusEl.className = `status ${ok ? "ok" : "err"}`;
  }

  function render(code: string) {
    if (player) { player.destroy(); player = null; }
    stage.innerHTML = "";
    try {
      player = createPlayer({ container: stage, code, assets, autoplay: true });
      setStatus(true);
    } catch (e) {
      const msg = (e as Error).message ?? String(e);
      stage.innerHTML = `<p class="parse-error">${msg}</p>`;
      setStatus(false);
    }
  }

  function setActiveBtn(index: number) {
    exBtns.forEach((b, i) => b.classList.toggle("active", i === index));
  }

  function getEditorCode(): string {
    return editorView?.state.doc.toString() ?? "";
  }

  function createEditor(initialCode: string) {
    // Destroy if existing
    if (editorView) {
      editorView.destroy();
      editorView = null;
    }

    const dark = isDarkMode();

    const extensions = [
      lineNumbers(),
      highlightActiveLine(),
      highlightActiveLineGutter(),
      history(),
      bracketMatching(),
      closeBrackets(),
      indentOnInput(),
      highlightSelectionMatches(),
      markdyLanguage,
      markdyAutocomplete,
      syntaxHighlighting(dark ? markdyHighlightDark : markdyHighlightLight),
      baseTheme,
      dark ? darkTheme : lightTheme,
      keymap.of([
        ...closeBracketsKeymap,
        ...defaultKeymap,
        ...searchKeymap,
        ...historyKeymap,
        indentWithTab,
      ]),
      EditorView.updateListener.of((update) => {
        if (update.docChanged) {
          exBtns.forEach(b => b.classList.remove("active"));
          if (debounce) clearTimeout(debounce);
          debounce = setTimeout(() => render(getEditorCode()), 600);
        }
      }),
    ];

    editorView = new EditorView({
      state: EditorState.create({
        doc: initialCode,
        extensions,
      }),
      parent: editorContainer,
    });
  }

  // Initial setup
  const initialCode = examples[0];
  createEditor(initialCode);
  render(initialCode);
  setActiveBtn(0);

  // Expose theme-change handler
  (window as any).__recreateEditor = () => {
    const currentCode = getEditorCode();
    createEditor(currentCode);
  };

  // Example buttons
  exBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const idx = Number(btn.dataset.index);
      setActiveBtn(idx);
      createEditor(examples[idx]);
      render(examples[idx]);
    });
  });

  // Run button
  runBtn.addEventListener("click", () => render(getEditorCode()));
</script>

<style>

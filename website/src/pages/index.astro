def char(skin, face) {'{'}
  figure(${'${skin}'}, f, ${'${face}'})
{'}'}

actor lily = char(${'${accent_skin}'}, 😊) at (100, 200)</code></pre>
        <script type="text/plain" class="ref-code-data">

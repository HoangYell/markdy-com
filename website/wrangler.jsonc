{
  // Cloudflare Workers + Assets configuration for markdy.com
  // Deploys the static Astro demo as a Workers-hosted static site.
  "name": "markdy-com",
  "compatibility_date": "2025-01-01",
  "assets": {
    // Output folder from `pnpm build` — relative to this wrangler.jsonc
    "directory": "./dist"
  }
}

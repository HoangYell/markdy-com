# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Personal access token with `repo` scope (https://github.com/settings/tokens)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Git identity to use when committing/pushing via scripts/github.sh
GITHUB_USERNAME=your-github-username
GITHUB_EMAIL=you@example.com

# Target repo (owner/repo)
GITHUB_REPO=your-github-username/markdy-com

# Remote head branch the script pushes to. Should be a *feature* branch
# (not a protected branch like `main`). Defaults to `${GITHUB_USERNAME}/wip`
# if left unset.
GITHUB_BRANCH=your-github-username/wip

# PR base branch — only used when running with --pr.
GITHUB_BASE_BRANCH=main

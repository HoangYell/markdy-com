# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Personal access token with `repo` scope (https://github.com/settings/tokens)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Git identity to use when committing/pushing via scripts/github.sh
GITHUB_USERNAME=your-github-username
GITHUB_EMAIL=you@example.com

# Target repo (owner/repo) and branch to push to
GITHUB_REPO=your-github-username/markdy-com
GITHUB_BRANCH=main

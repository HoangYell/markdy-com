{
  "name": "@markdy/mdx",
  "version": "0.7.19",
  "description": "MDX integration plugin and lightweight React player for Markdy.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "markdy",
    "mdx",
    "remark",
    "react",
    "animation"
  ],
  "author": "Hoang Yell <hoangyell@gmail.com> (https://hoangyell.com)",
  "homepage": "https://markdy.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/HoangYell/markdy-com.git",
    "directory": "packages/mdx"
  },
  "bugs": {
    "url": "https://github.com/HoangYell/markdy-com/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "echo \"No tests yet\"",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@markdy/renderer-dom": "workspace:*",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}

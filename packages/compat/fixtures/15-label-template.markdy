# Reusable labels via def template
scene width=800 height=300 bg=white

def label(txt) {
  text(${txt})
}

actor a = label("Round 1") at (150, 130) size 40 opacity 0
actor b = label("FIGHT!")  at (470, 130) size 48 opacity 0

@0.2: a.fade_in(dur=0.4)
@0.8: a.fade_out(dur=0.3)
@1.3: b.fade_in(dur=0.4)
@2.0: b.scale(to=1.4, dur=0.5, ease=out)

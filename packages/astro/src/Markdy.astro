---
/**
 * @markdy/astro — <Markdy /> island component
 *
 * SSR: renders a correctly-sized placeholder div so layout is stable.
 *      Exposes `title` / `description` for SEO and a `<noscript>` block
 *      so search-engine crawlers that do not execute JavaScript still
 *      index meaningful text.
 * Client: hydrates via IntersectionObserver when the element enters the
 *         viewport. The renderer is dynamically imported so it is fully
 *         code-split from the host-page bundle and never blocks the
 *         critical rendering path.
 */

export interface Props {
  /** MarkdyScript source code. */
  code: string;
  /**
   * Placeholder width in pixels (should match the `width` in the scene
   * declaration). Used only for the SSR placeholder — the renderer reads
   * the actual value from the parsed AST.
   */
  width?: number;
  /** Placeholder height in pixels. */
  height?: number;
  /**
   * Placeholder background colour. Pass the same value as `bg` in the
   * scene declaration so there is no flash on hydration.
   */
  bg?: string;
  /**
   * Asset URL overrides.  Keys are the asset names used in the DSL.
   * Values are the URLs the renderer should use instead of the parsed path.
   * Useful for CDN assets or data URIs in demos.
   */
  assets?: Record<string, string>;
  /** Start playing as soon as the scene is hydrated. Defaults to true. */
  autoplay?: boolean;
  /** Loop the animation when it ends. Defaults to true. */
  loop?: boolean;
  /** Show a small "Powered by Markdy" badge below the animation. Defaults to true. */
  copyright?: boolean;
  /** Show a rainbow progress bar around the viewport border. Defaults to true. */
  progressBar?: boolean;
  class?: string;
  /**
   * Short human-readable title for the animation.
   * Used as the accessible name (`aria-label`) and treated like `alt` on
   * an image for SEO purposes.
   */
  title?: string;
  /**
   * Longer description rendered inside `<noscript>` so crawlers that do
   * not run JavaScript still index meaningful content.
   */
  description?: string;
}

const {
  code,
  width = 800,
  height = 400,
  bg = "white",
  assets = {},
  autoplay = true,
  loop = true,
  copyright = true,
  progressBar = true,
  class: className,
  title = "Markdy animation",
  description,
} = Astro.props;
---

<div
  class:list={["markdy-root", className]}
  data-markdy-code={code}
  data-markdy-assets={JSON.stringify(assets)}
  data-markdy-autoplay={String(autoplay)}
  data-markdy-loop={String(loop)}
  data-markdy-copyright={String(copyright)}
  data-markdy-progress-bar={String(progressBar)}
  role="img"
  aria-label={title}
  aria-busy="true"
  style={`max-width:${width}px;width:100%;aspect-ratio:${width}/${height};overflow:hidden`}
>
  <!--
    SSR placeholder: keeps layout stable before the island hydrates.
    Background matches the scene bg prop to avoid a visible flash.
    aria-hidden because the parent role="img" aria-label carries the
    accessible name — this inner text is decorative.
  -->
  <div
    class="markdy-placeholder"
    aria-hidden="true"
    style={`width:100%;height:100%;background:${bg};display:flex;align-items:center;justify-content:center;cursor:pointer`}
  >
    <span
      style="font-family:sans-serif;font-size:12px;color:#bbb;letter-spacing:0.05em"
    >
      ▶ markdy
    </span>
  </div>

  <!--
    noscript fallback: rendered for crawlers / users that do not run JS.
    Provides indexable text content so the animation does not become an
    opaque block in search results.
  -->
  <noscript>
    <div
      style={`width:100%;height:100%;background:${bg};display:flex;align-items:center;justify-content:center`}
    >
      <p
        style="font-family:sans-serif;font-size:14px;color:#888;text-align:center;padding:1rem;margin:0"
      >
        {description ?? title}
      </p>
    </div>
  </noscript>
</div>

<script>
  // ── Hydration ────────────────────────────────────────────────────────────
  // The renderer is dynamically imported so it is code-split from the
  // host-page bundle.  The browser only downloads it when an element is
  // about to enter the viewport, keeping Time-to-Interactive low.

  async function hydrate(el: HTMLElement): Promise<void> {
    const code = el.dataset.markdyCode;
    if (!code) return;

    let assets: Record<string, string> = {};
    try {
      assets = JSON.parse(el.dataset.markdyAssets ?? "{}") as Record<
        string,
        string
      >;
    } catch {
      // Leave assets empty on parse failure — renderer falls back to DSL paths.
    }

    const autoplay = el.dataset.markdyAutoplay !== "false";
    const loop = el.dataset.markdyLoop !== "false";
    const copyright = el.dataset.markdyCopyright !== "false";
    const progressBar = el.dataset.markdyProgressBar !== "false";

    // Code-split: renderer-dom is NOT part of the initial page bundle.
    const { createPlayer } = await import("@markdy/renderer-dom");

    // Clear the SSR placeholder and mount the canvas atomically after the
    // async import resolves, so there is no flash of empty content.
    el.innerHTML = "";

    createPlayer({ container: el, code, assets, autoplay, loop, copyright, progressBar });

    el.dataset.markdyInit = "done";
    el.removeAttribute("aria-busy");
  }

  // ── Task scheduling ──────────────────────────────────────────────────────
  // Yield a macro-task slot before running heavy work so we never block
  // user input or the frame pipeline.
  //   1. Prioritized Task Scheduling API  — Chrome 94+, Safari 17+
  //   2. requestIdleCallback              — broad support
  //   3. setTimeout(0)                    — universal fallback

  type SchedulerLike = {
    postTask: (fn: () => void, opts: { priority: string }) => void;
  };

  function scheduleHydration(fn: () => void): void {
    const sched = (globalThis as unknown as { scheduler?: SchedulerLike })
      .scheduler;
    if (sched?.postTask) {
      sched.postTask(fn, { priority: "background" });
    } else if (typeof requestIdleCallback !== "undefined") {
      requestIdleCallback(fn, { timeout: 2000 });
    } else {
      setTimeout(fn, 0);
    }
  }

  // ── Intersection observer ────────────────────────────────────────────────
  // threshold: 0.25 — trigger as soon as a quarter of the element is visible.
  // We intentionally avoid threshold: 1.0 because it is unreliable: on first
  // navigation (fresh link, no F5) the browser may not fire the callback when
  // the element is very close to — but not fully inside — the viewport.

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          observer.unobserve(el);
          // Mark immediately to prevent double-scheduling on re-runs.
          el.dataset.markdyInit = "hydrating";
          scheduleHydration(() => {
            hydrate(el).catch(() => {
              // On failure keep the placeholder visible — do not crash the page.
              el.dataset.markdyInit = "error";
              el.removeAttribute("aria-busy");
            });
          });
        }
      }
    },
    { threshold: 0.25 },
  );

  function doHydrate(el: HTMLElement): void {
    observer.unobserve(el);
    el.dataset.markdyInit = "hydrating";
    scheduleHydration(() => {
      hydrate(el).catch(() => {
        el.dataset.markdyInit = "error";
        el.removeAttribute("aria-busy");
      });
    });
  }

  function initAll(): void {
    document
      .querySelectorAll<HTMLElement>(".markdy-root:not([data-markdy-init])")
      .forEach((el) => {
        el.dataset.markdyInit = "pending";
        // Proactively hydrate elements already in the viewport so we never
        // depend on the observer firing for elements visible at page load.
        // This fixes autoplay on first navigation from an external site where
        // IntersectionObserver callbacks may be delayed or skipped.
        const rect = el.getBoundingClientRect();
        const inViewport =
          rect.bottom > 0 &&
          rect.right > 0 &&
          rect.top < (window.innerHeight || document.documentElement.clientHeight) &&
          rect.left < (window.innerWidth || document.documentElement.clientWidth);
        if (inViewport) {
          doHydrate(el);
        } else {
          observer.observe(el);
        }
      });
  }

  // Initial page load.
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAll);
  } else {
    initAll();
  }

  // Re-run after Astro View Transitions / client-side navigation.
  document.addEventListener("astro:page-load", initAll);

  // Click on placeholder to play immediately without waiting for full visibility.
  document.addEventListener("click", (e) => {
    const placeholder = (e.target as Element).closest(".markdy-placeholder");
    if (!placeholder) return;
    const root = placeholder.closest<HTMLElement>(".markdy-root");
    if (!root) return;
    const state = root.dataset.markdyInit;
    if (state === "done" || state === "hydrating") return;
    doHydrate(root);
  });
</script>

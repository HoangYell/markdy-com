---
import Layout from "../layouts/Layout.astro";
import { Markdy } from "@markdy/astro";

// ---------------------------------------------------------------------------
// Story: 2 stick-figure guys (Bruno & Alex) love Lily
//        → they fight → winner offers flower → Lily rejects → comforts loser
//
// Showcases the full DSL feature set:
//   var   — reusable constants (skin colours, positions)
//   def   — user-defined actor templates (fighter, heroine)
//   seq   — reusable animation sequences (wave, entrance, punch_combo, …)
//   play  — invoke sequences on any actor with params
//   face  — runtime emoji expression swap
// ---------------------------------------------------------------------------

const STORY = `
scene width=920 height=460 fps=30 bg=#fff5f9

# ── Variables ─────────────────────────────────────────────────────────────
var skin_bruno = #c68642
var skin_alex  = #8d5524
var skin_lily  = #fad4c0
var fight_y    = 200

# ── Templates ─────────────────────────────────────────────────────────────
def fighter(skin, face) {
  figure(\${skin}, m, \${face})
}

def heroine(skin, face) {
  figure(\${skin}, f, \${face})
}

# ── Sequences ─────────────────────────────────────────────────────────────
seq entrance(side) {
  @+0.0: $.enter(from=\${side}, dur=1.0)
}

seq wave_arm(arm, angle) {
  @+0.0: $.rotate_part(part=\${arm}, to=\${angle}, dur=0.3)
  @+0.3: $.rotate_part(part=\${arm}, to=25, dur=0.3)
}

seq head_shake {
  @+0.0: $.rotate_part(part=head, to=10, dur=0.25)
  @+0.3: $.rotate_part(part=head, to=-10, dur=0.25)
  @+0.6: $.rotate_part(part=head, to=0, dur=0.2)
}

seq punch_hit(side, intensity) {
  @+0.0: $.punch(side=\${side}, dur=0.32)
  @+0.05: $.shake(intensity=\${intensity}, dur=0.3)
}

seq body_clash(angle) {
  @+0.0: $.rotate_part(part=body, to=\${angle}, dur=0.2)
  @+0.2: $.rotate_part(part=body, to=0, dur=0.2)
}

seq celebrate {
  @+0.0: $.rotate_part(part=arm_right, to=-130, dur=0.3)
  @+0.4: $.rotate_part(part=arm_right, to=-25, dur=0.4)
}

# ── Assets ────────────────────────────────────────────────────────────────
asset flower = image("/memes/flower.png")

# ── Actors (using templates!) ─────────────────────────────────────────────
actor bruno = fighter(\${skin_bruno}, 😏) at (740, \${fight_y})
actor alex  = fighter(\${skin_alex}, 😤)  at (120, \${fight_y})
actor lily  = heroine(\${skin_lily}, 😊)  at (430, \${fight_y}) opacity 0

# ── Act 1: entrances ─────────────────────────────────────────────────────
@0.0: lily.fade_in(dur=0.7)
@0.8: bruno.play(entrance, side=right)
@1.1: alex.play(entrance, side=left)

# Idle wave — using the wave_arm sequence
@2.2: bruno.play(wave_arm, arm=arm_left, angle=-80)
@2.2: alex.play(wave_arm, arm=arm_right, angle=80)

# ── Act 2: declarations ───────────────────────────────────────────────────
@3.0: bruno.face("😍")
@3.0: alex.face("😍")
@3.1: bruno.say("I love you! 😍", dur=1.4)
@3.6: alex.say("She is mine! 😤",  dur=1.4)
@3.7: alex.face("😤")
@5.2: lily.face("😳")
@5.2: lily.say("Oh my... 😳",      dur=1.1)
@5.2: lily.play(head_shake)

# ── Act 3: rivals charge ──────────────────────────────────────────────────
@6.5: lily.face("😬")
@6.5: lily.move(to=(810, \${fight_y}), dur=0.5, ease=out)
@6.9: bruno.face("😠")
@6.9: alex.face("😠")
@7.0: bruno.move(to=(455, \${fight_y}), dur=0.65, ease=in)
@7.0: alex.move(to=(370, \${fight_y}),  dur=0.65, ease=in)

# ── Act 4: fight! (using punch_hit + body_clash sequences) ───────────────
@7.8:  bruno.play(punch_hit, side=left, intensity=7)
@7.8:  alex.play(punch_hit, side=right, intensity=7)
@7.85: bruno.face("😵")
@7.85: alex.face("😵")

@8.3:  alex.kick(side=right,   dur=0.36)
@8.3:  alex.face("😡")
@8.4:  bruno.shake(intensity=9, dur=0.32)
@8.4:  bruno.face("😬")
@8.5:  bruno.play(punch_hit, side=left, intensity=8)
@8.5:  bruno.face("😡")
@8.55: alex.face("😵")

@8.95: alex.play(body_clash, angle=15)
@8.95: bruno.play(body_clash, angle=-10)

# Finishing blow
@9.4:  bruno.punch(side=left, dur=0.25)
@9.45: alex.rotate_part(part=head, to=35, dur=0.2)
@9.5:  alex.shake(intensity=12, dur=0.45)
@9.5:  alex.face("😵‍💫")

# ── Act 5: knockout ───────────────────────────────────────────────────────
@10.1: alex.rotate(to=90, dur=0.4)
@10.1: alex.face("😶")
@10.2: alex.move(to=(370, 310), dur=0.4, ease=in)
@10.4: alex.fade_out(dur=0.45)
@10.1: bruno.face("😁")
@10.1: bruno.say("I win! 💪",   dur=1.5)
@10.1: bruno.play(celebrate)

# ── Act 6: approaches with flower ─────────────────────────────────────────
@11.8: bruno.face("🥰")
@11.8: bruno.move(to=(580, \${fight_y}), dur=0.9, ease=out)
@11.8: bruno.rotate_part(part=arm_left, to=-90, dur=0.5)
@13.0: bruno.throw(flower, to=lily, dur=0.8)

# ── Act 7: rejection ──────────────────────────────────────────────────────
@14.0: lily.face("🙅")
@14.0: lily.say("No thank you. 🙅", dur=2.0)
@14.1: lily.shake(intensity=5, dur=0.4)
@14.1: lily.rotate_part(part=arm_right, to=80, dur=0.3)
@14.5: lily.rotate_part(part=arm_right, to=8,  dur=0.3)
@16.0: bruno.face("😢")
@16.2: bruno.say("But I fought! 😢", dur=1.4)
@16.2: bruno.rotate_part(part=head, to=10, dur=0.3)
@16.7: bruno.move(to=(860, \${fight_y}), dur=1.2, ease=in)

# ── Act 8: girl comforts loser ────────────────────────────────────────────
@18.0: alex.fade_in(dur=0.7)
@18.0: lily.face("🥺")
@18.5: lily.move(to=(450, \${fight_y}), dur=0.5, ease=out)
@19.3: lily.move(to=(375, 305), dur=0.9, ease=inout)
@20.3: lily.rotate_part(part=arm_right, to=-70, dur=0.35)
@20.6: lily.face("🤗")
@20.6: lily.say("Hey, you okay? 💕", dur=2.1)
@20.8: alex.face("🥺")
@20.8: alex.say("You came... 🥺",    dur=1.9)
@21.0: alex.rotate_part(part=arm_left, to=-60, dur=0.4)

# ── Act 9: curtain ────────────────────────────────────────────────────────
@23.0: bruno.face("😔")
@23.0: bruno.say("...why 😔", dur=2.0)
@23.0: bruno.rotate_part(part=head, to=-15, dur=0.5)
`.trim();

// Pre-encoded SVG flower (no raw angle-brackets to avoid Vite HTML parsing)
const STORY_ASSETS: Record<string, string> = {
  flower:
    "data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20width%3D'36'%20height%3D'36'%3E%3Ccircle%20cx%3D'18'%20cy%3D'18'%20r%3D'16'%20fill%3D'%23ff69b4'%2F%3E%3Ccircle%20cx%3D'18'%20cy%3D'18'%20r%3D'6'%20fill%3D'%23ffff00'%2F%3E%3C%2Fsvg%3E",
};

const ACTS = [
  { time: "0s",    label: "Lily appears; Bruno & Alex enter from opposite sides" },
  { time: "2.2s",  label: "Idle wave — arm_left / arm_right rotate_part" },
  { time: "3.1s",  label: "Declarations of love; Lily's head tilts (head rotate_part)" },
  { time: "7.0s",  label: "Lily steps aside — rivals charge" },
  { time: "7.8s",  label: "Fight: punches, kicks, body/head rotations" },
  { time: "10.1s", label: "Alex is knocked out — fist pump (arm_right rotate_part)" },
  { time: "11.8s", label: "Bruno approaches holding flower" },
  { time: "14.0s", label: "Lily rejects — arm wave, head shake" },
  { time: "18.0s", label: "Lily kneels to comfort Alex" },
  { time: "23.0s", label: "Bruno alone, head drooping 😔" },
];
---

<Layout title="Playground — Markdy" description="A MarkdyScript story animation: two rivals, one heart.">
  <main>
    <nav class="breadcrumb">
      <a href="/">← Demo home</a>
    </nav>

    <header>
      <h1>Playground</h1>
      <p class="subtitle">
        Stick figures with body parts — punch, kick, rotate any limb. (~25 s)
      </p>
    </header>

    <div class="stage">
      <Markdy
        code={STORY}
        assets={STORY_ASSETS}
        width={920}
        height={460}
        bg="#fff5f9"
        autoplay={true}
      />
    </div>

    <div class="legend">
      <h2>Story acts</h2>
      <ol>
        {ACTS.map(({ time, label }) => (
          <li>
            <span class="timestamp">{time}</span>
            <span class="act-label">{label}</span>
          </li>
        ))}
      </ol>
    </div>

    <details class="source-panel">
      <summary>View MarkdyScript source</summary>
      <pre><code>{STORY}</code></pre>
    </details>
  </main>
</Layout>

<style>
  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
  }

  .breadcrumb {
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }

  .breadcrumb a {
    color: #666;
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: #0066cc;
  }

  header {
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: #666;
    font-size: 1rem;
  }

  .stage {
    border: 1px solid #e0cce8;
    border-radius: 12px;
    overflow: hidden;
    display: inline-block;
    box-shadow: 0 4px 24px rgba(180, 100, 200, 0.1);
    margin-bottom: 1.5rem;
    max-width: 100%;
  }

  .legend {
    margin-bottom: 1.5rem;
  }

  .legend h2 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: #444;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.8rem;
  }

  .legend ol {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    padding: 0;
  }

  .legend li {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: #555;
    min-width: 220px;
  }

  .timestamp {
    font-family: "Fira Code", "Cascadia Code", monospace;
    font-size: 0.78rem;
    color: #a855f7;
    min-width: 3.5rem;
    font-weight: 600;
  }

  .source-panel {
    margin-top: 0.5rem;
  }

  summary {
    cursor: pointer;
    font-size: 0.875rem;
    color: #0066cc;
    user-select: none;
    margin-bottom: 0.5rem;
  }

  pre {
    background: #f9f0ff;
    border: 1px solid #e0cce8;
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    font-size: 0.82rem;
    line-height: 1.6;
    white-space: pre;
  }

  code {
    font-family: "Fira Code", "Cascadia Code", "Consolas", monospace;
  }
</style>
